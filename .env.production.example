# SERVER CONFIGURATION
PORT=4000
NODE_ENV=production
FRONTEND_URL=https://smartrose.example.com

# DATABASE CONFIGURATION
DB_USER=smartrose
DB_PASSWORD=your_production_db_password
DB_NAME=smartrose_prod
DATABASE_URL=postgresql://${DB_USER}:${DB_PASSWORD}@postgres:5432/${DB_NAME}?schema=public

# REDIS CONFIGURATION
REDIS_PASSWORD=your_production_redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# STORAGE CONFIGURATION (MinIO or S3 Compatible)
# Catatan: STORAGE_PROVIDER harus diisi sesuai provider storage production (misal S3 atau MinIO self-hosted di VPS)
STORAGE_PROVIDER=s3
STORAGE_ENDPOINT=s3.example.com
STORAGE_PORT=443
STORAGE_USE_SSL=true
STORAGE_ACCESS_KEY=your_production_access_key
STORAGE_SECRET_KEY=your_production_secret_key
STORAGE_BUCKET_NAME=smartrose-attachments

# SMTP EMAIL CONFIGURATION
# Catatan: SMTP_HOST diisi smtp-relay.brevo.com, SMTP_PORT 587
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your_brevo_username
SMTP_PASS=your_brevo_password
SMTP_FROM_EMAIL=noreply@smartrose.example.com
SMTP_FROM_NAME="SMART-ROSE System"

# SECURITY & AUTHENTICATION
# Catatan: JWT_ACCESS_SECRET, JWT_REFRESH_SECRET, ENCRYPTION_KEY WAJIB digenerate baru khusus production, jangan reuse dari development.
JWT_ACCESS_SECRET=generate_your_secure_access_secret_here
JWT_REFRESH_SECRET=generate_your_secure_refresh_secret_here
JWT_ACCESS_EXPIRATION=15m
JWT_REFRESH_EXPIRATION=7d
ENCRYPTION_KEY=generate_your_secure_32_byte_encryption_key_here
