# App
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000

# Database (Postgres lokal Docker — nanti tinggal ganti connection string saat pindah ke VPS/Supabase)
DATABASE_URL=postgresql://smartrose:smartrose_dev_pass@localhost:5432/smartrose_dev
DIRECT_URL=postgresql://smartrose:smartrose_dev_pass@localhost:5432/smartrose_dev

# ============================================
# STORAGE_PROVIDER: "local" (MinIO/S3-compatible) atau "supabase" (kalau nanti pakai Supabase)
# ============================================
STORAGE_PROVIDER=local

# -- Dipakai jika STORAGE_PROVIDER=local --
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=smartrose_admin
MINIO_SECRET_KEY=smartrose_minio_pass
MINIO_BUCKET=report-attachments

# -- Dipakai jika STORAGE_PROVIDER=supabase (kosongkan dulu, isi nanti kalau dipakai) --
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=

# Redis (lokal Docker)
REDIS_URL=redis://localhost:6379

# JWT
JWT_ACCESS_SECRET=f492e72b28539f815242710bffde18267c46ee0bfd9e7e12a4502473e497b24b
JWT_REFRESH_SECRET=20e942b4ae34c07ea5c261bdab0d39f552d6cafd995662e1d5daad0b944cf855
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1y

# Encryption (dipakai mulai Fase 7, siapkan dari sekarang)
ENCRYPTION_KEY=139b3761efb49edebbadaf7922396b2fc10f9f8a927fb64239166f7fe03cbd2c

# Sentry (kosongkan dulu -> otomatis nonaktif)
SENTRY_DSN=

# Mail (Mailhog lokal, tidak butuh auth)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=