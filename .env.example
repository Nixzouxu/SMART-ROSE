# =============================================================================
# SMART-ROSE - Template Environment Variables
# Salin file ini menjadi .env.development (untuk lokal) atau .env (untuk prod)
# JANGAN commit file .env atau .env.development ke repository
# =============================================================================

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
NODE_ENV=development
PORT=4000
APP_URL=http://localhost:4000

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# Sesuaikan dengan kredensial docker-compose.dev.yml saat development lokal
# -----------------------------------------------------------------------------
DATABASE_URL=postgresql://user:password@localhost:5432/nama_database
DIRECT_URL=postgresql://user:password@localhost:5432/nama_database

# -----------------------------------------------------------------------------
# Storage Provider
# Pilih: "local" (pakai MinIO lokal) atau "supabase" (pakai Supabase Storage)
# -----------------------------------------------------------------------------
STORAGE_PROVIDER=local

# -- Dipakai jika STORAGE_PROVIDER=local (MinIO / S3-compatible) --
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=ganti_sesuai_kredensial_minio_lokal
MINIO_SECRET_KEY=ganti_sesuai_kredensial_minio_lokal
MINIO_BUCKET=report-attachments

# -- Dipakai jika STORAGE_PROVIDER=supabase (kosongkan jika tidak dipakai) --
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=ganti_dengan_anon_key_dari_dashboard_supabase
SUPABASE_SERVICE_ROLE_KEY=ganti_dengan_service_role_key_dari_dashboard_supabase
SUPABASE_STORAGE_BUCKET=ganti_dengan_nama_bucket_supabase

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_URL=redis://localhost:6379

# -----------------------------------------------------------------------------
# JWT
# Gunakan string acak minimal 32 karakter, contoh generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
JWT_ACCESS_SECRET=ganti_dengan_secret_minimal_32_karakter_acak
JWT_REFRESH_SECRET=ganti_dengan_secret_minimal_32_karakter_acak
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=1y

# -----------------------------------------------------------------------------
# Encryption Key
# Harus tepat 64 karakter hex (= 32 byte), contoh generate:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# -----------------------------------------------------------------------------
ENCRYPTION_KEY=ganti_dengan_64_karakter_hex_acak

# -----------------------------------------------------------------------------
# Sentry (opsional, kosongkan untuk nonaktifkan)
# -----------------------------------------------------------------------------
SENTRY_DSN=

# -----------------------------------------------------------------------------
# Mail (SMTP)
# Development lokal: gunakan Mailhog (tidak butuh autentikasi)
# -----------------------------------------------------------------------------
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
